# Pinned ColabFold / JAX stack for Longleaf (Python 3.9, CUDA 12, ColabFold 1.5.5).
# Sourced by setup/repair/verify scripts — edit versions here only.

export COLABFOLD_JAX_VERSION="${COLABFOLD_JAX_VERSION:-0.4.27}"
# haiku 0.0.10 needs jax<=0.4.23; haiku 0.0.12+ fixes jax.linear_util for jax>=0.4.24.
# Do NOT use haiku>=0.0.14 on Python 3.9 (uses bool|None type hints).
export COLABFOLD_HAIKU_VERSION="${COLABFOLD_HAIKU_VERSION:-0.0.12}"
export COLABFOLD_CHEX_VERSION="${COLABFOLD_CHEX_VERSION:-0.1.90}"
export JAX_CUDA_RELEASES_URL="${JAX_CUDA_RELEASES_URL:-https://storage.googleapis.com/jax-releases/jax_cuda_releases.html}"
