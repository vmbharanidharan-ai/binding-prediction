Bootstrap: docker
From: nvidia/cuda:11.1.1-runtime-ubuntu20.04

# RFdiffusion Apptainer image for Longleaf GPU nodes.
# Build (on GPU node): apptainer build --nv rfdiffusion.sif containers/rfdiffusion.def
# Test: apptainer exec --nv rfdiffusion.sif python -c "import torch, dgl, rfdiffusion"

%help
RFdiffusion GPU container: torch 1.9.1+cu111, DGL 1.0.0, SE3Transformer, RFdiffusion.
Model weights are bind-mounted at runtime from host RFdiffusion/models.

%labels
Author "binding-prediction"
Version "1.1"
PyTorch "1.9.1+cu111"
CUDA "11.1"
Python "3.9"

%environment
export LC_ALL=C
export LANG=C.UTF-8
export CUDA_HOME=/usr/local/cuda-11.1
export LD_LIBRARY_PATH=/usr/local/cuda-11.1/lib64:${LD_LIBRARY_PATH:-}
export DGLBACKEND=pytorch

%post
    # Non-interactive apt (avoids tzdata timezone prompt hanging automated builds)
    export DEBIAN_FRONTEND=noninteractive
    export TZ=UTC
    ln -snf /usr/share/zoneinfo/$TZ /etc/localtime && echo $TZ > /etc/timezone

    apt-get update
    apt-get install -y --no-install-recommends \
        build-essential \
        ca-certificates \
        curl \
        git \
        wget \
        libopenmpi-dev \
        openmpi-bin \
        pkg-config \
        libhdf5-dev \
        libssl-dev \
        libffi-dev \
        python3.9 \
        python3.9-dev \
        python3.9-distutils \
        python3-pip

    update-alternatives --install /usr/bin/python python /usr/bin/python3.9 1
    update-alternatives --install /usr/bin/pip pip /usr/bin/pip3 1
    python -m pip install --upgrade pip setuptools wheel

    # PyTorch 1.9.1 + CUDA 11.1 (must stay pinned — RFdiffusion/DGL require this stack)
    pip install --no-cache-dir \
        torch==1.9.1+cu111 \
        torchvision==0.10.1+cu111 \
        torchaudio==0.9.1 \
        -f https://download.pytorch.org/whl/torch_stable.html

    pip install --no-cache-dir numpy==1.23.5 scipy==1.10.1

    # CUDA DGL: cu111 wheels removed from data.dgl.ai (Access Denied).
    # Use cu113 wheel (~259 MB); compatible with torch 1.9.1+cu111 on Longleaf GPUs.
    DGL_WHEEL=/tmp/dgl-1.0.0+cu113-cp39-cp39-manylinux1_x86_64.whl
    wget -O "$DGL_WHEEL" \
        "https://data.dgl.ai/wheels/cu113/dgl-1.0.0%2Bcu113-cp39-cp39-manylinux1_x86_64.whl"
    test -s "$DGL_WHEEL" || { echo "ERROR: DGL wheel download failed"; exit 1; }
    pip install --no-cache-dir "$DGL_WHEEL"
    rm -f "$DGL_WHEEL"

    python - <<'PYEOF'
import glob
import os
import sys

libs = glob.glob("/usr/local/lib/python3.9/dist-packages/dgl/libdgl.so")
if not libs:
    print("ERROR: libdgl.so not found after DGL install")
    sys.exit(1)
size_mb = os.path.getsize(libs[0]) / (1024 * 1024)
print(f"libdgl.so size: {size_mb:.1f} MB")
if size_mb < 20:
    print("ERROR: DGL looks like CPU build (libdgl.so too small); need CUDA wheel")
    sys.exit(1)
PYEOF

    pip install --no-cache-dir \
        networkx requests tqdm psutil charset-normalizer pillow

    # Hydra only here — do NOT install unpinned e3nn (0.6.0+ pulls torch>=2.2)
    pip install --no-cache-dir hydra-core pyrsistent omegaconf

    mkdir -p /opt/rfdiffusion
    cd /opt/rfdiffusion
    git clone --depth 1 https://github.com/RosettaCommons/RFdiffusion.git .

    # SE3Transformer from RFdiffusion tree (pins e3nn==0.3.3 via requirements.txt)
    cd env/SE3Transformer
    pip install --no-cache-dir -r requirements.txt
    # pip install (not setup.py install) — setup.py puts files in site-packages
    # that may not be on sys.path; cwd-only import falsely passes verify step
    pip install --no-cache-dir --no-build-isolation .
    cd /opt/rfdiffusion
    python -c "import se3_transformer; print('SE3Transformer OK:', se3_transformer.__file__)" || exit 1

    # --no-deps: se3-transformer is not on PyPI; already installed from source above
    pip install --no-cache-dir --no-deps -e .
    cd /opt/rfdiffusion
    python -c "import rfdiffusion; print(f'RFdiffusion OK: {rfdiffusion.__file__}')" || exit 1
    python -c "import se3_transformer; print(f'SE3Transformer path: {se3_transformer.__file__}')" || exit 1

    python - <<'PYEOF'
import sys
import torch
import numpy
import scipy
import dgl
import hydra
import se3_transformer
import rfdiffusion

if not torch.__version__.startswith("1.9."):
    print(f"ERROR: torch {torch.__version__} — expected 1.9.x (e3nn pin failed)")
    sys.exit(1)

print(f"torch {torch.__version__}")
print(f"numpy {numpy.__version__}")
print(f"scipy {scipy.__version__}")
print(f"dgl {dgl.__version__}")
print(f"hydra {hydra.__version__}")
print(f"se3_transformer OK")
print(f"rfdiffusion {rfdiffusion.__file__}")
print("All imports successful")
PYEOF

    apt-get clean
    rm -rf /var/lib/apt/lists/* /root/.cache/pip

%runscript
    exec python "$@"
